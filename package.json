    "react": "16.8.6",
    "react-display-name": "0.2.4",
    "react-dom": "16.8.6",
    "react-motion": "0.5.2",
    "react-redux": "6.0.1",
    "react-svg-loader": "2.1.0",
    "redux": "4.0.1",
    "style-loader": "0.23.1",
    "styled-components": "4.2.0",
    "terser-webpack-plugin": "1.2.3",
    "typescript": "3.3.4000",
    "url-loader": "1.1.2",
    "webpack": "4.29.6",
    "webpack-bundle-analyzer": "3.1.0",
    "webpack-cli": "3.3.0",
    "webpack-dev-server": "3.2.1"
  },
  "dependencies": {
    "@babel/runtime": "^7.3.4",
    "lodash": "4.17.13",
    "prop-types": "^15.6.0",
    "react-collapse": "^4.0.3",
    "react-portal": "^4.2.0",
    "react-transition-group": "^1.2.0"
  }
}
