{
  "name": "@purrnuu/particular",
  "version": "0.2.0",
  "description": "An opinionated Particle Engine",
  "keywords": [
    "particles",
    "particle-engine",
    "webgl",
    "canvas",
    "react",
    "animation",
    "effects",
    "confetti",
    "snow"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/particular.global.js",
  "jsdelivr": "./dist/particular.global.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./standalone": {
      "import": {
        "types": "./dist/standalone.d.ts",
        "default": "./dist/standalone.js"
      },
      "require": {
        "types": "./dist/standalone.d.cts",
        "default": "./dist/standalone.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:lib && npm run build:storybook",
    "build:lib": "tsup",
    "build:storybook": "storybook build -o ./docs",
    "lint": "eslint ./src --ext ts,tsx",
    "lint:fix": "eslint ./src --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:embed": "npm run build:lib && vitest run tests/embed.test.ts",
    "test:watch": "vitest",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "example:vanilla": "npm run build:lib && python3 -m http.server 8080",
    "example:react": "npm run build:lib && npm --prefix examples/react install && npm --prefix examples/react run dev",
    "prepublishOnly": "npm run build:lib",
    "prerelease": "npm run build:lib && npm test && npm run type-check",
    "release:patch": "npm run prerelease && npm version patch && git push && git push --tags && npm publish && gh release create v$(node -p \"require('./package.json').version\") --generate-notes",
    "release:minor": "npm run prerelease && npm version minor && git push && git push --tags && npm publish && gh release create v$(node -p \"require('./package.json').version\") --generate-notes",
    "release:major": "npm run prerelease && npm version major && git push && git push --tags && npm publish && gh release create v$(node -p \"require('./package.json').version\") --generate-notes",
    "clean": "rm -rf dist lib docs"
  },
  "author": "Niilo Säämänen <purrnuu@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Purrnuu/particular.git"
  },
  "homepage": "https://purrnuu.github.io/particular/",
  "bugs": {
    "url": "https://github.com/Purrnuu/particular/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.5.0",
    "@storybook/addon-interactions": "^8.5.0",
    "@storybook/addon-links": "^8.5.0",
    "@storybook/blocks": "^8.5.0",
    "@storybook/react": "^8.5.0",
    "@storybook/react-vite": "^8.5.0",
    "@storybook/test": "^8.5.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.5.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "dependencies": {}
}
