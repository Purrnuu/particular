{
  "name": "particular",
  "version": "0.1.0",
  "description": "An opinionated Particle Engine",
  "main": "./lib/index.js",
  "scripts": {
    "build": "npm run build-lib && npm run build-storybook",
    "build-storybook": "build-storybook -c .storybook -o ./docs",
    "build-lib": "webpack --config webpack.config.js --progress --colors --mode=production",
    "build-lib-stats": "webpack -p --config webpack.config.js --profile --json > stats.json",
    "lint": "eslint ./src --ext js,jsx,ts,tsx",
    "test": "NODE_ENV=test jest ./src",
    "test:watch": "npm run test -- --watch",
    "start": "yarn storybook",
    "storybook": "start-storybook -p 6006",
    "prepublishOnly": "npm run build",
    "analyze-bundle-size": "ANALYZE_BUNDLE=true npm run build-lib"
  },
  "author": "Niilo Säämänen <niilo@muffinssi.com>",
  "license": "MIT",
  "peerDependencies": {
    "classnames": "^2.2.0",
    "ramda": "^0.26.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "react-motion": "~0.5.0",
    "styled-components": ">=4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,scss,scssm,json,md}": [
      "prettier --write",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "devDependencies": {
    "@babel/core": "7.4.0",
    "@babel/plugin-proposal-class-properties": "7.4.0",
    "@babel/plugin-proposal-export-default-from": "7.2.0",
    "@babel/plugin-proposal-export-namespace-from": "7.2.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "7.2.0",
    "@babel/plugin-proposal-object-rest-spread": "7.4.0",
    "@babel/plugin-proposal-optional-chaining": "7.2.0",
    "@babel/plugin-proposal-pipeline-operator": "7.3.2",
    "@babel/plugin-syntax-dynamic-import": "7.2.0",
    "@babel/plugin-transform-runtime": "7.4.0",
    "@babel/preset-env": "7.4.2",
    "@babel/preset-react": "7.0.0",
    "@babel/preset-typescript": "7.3.3",
    "@storybook/addon-actions": "5.0.6",
    "@storybook/addon-knobs": "5.0.6",
    "@storybook/core": "5.0.6",
    "@storybook/react": "5.0.6",
    "@storybook/theming": "5.0.6",
    "@types/classnames": "2.2.7",
    "@types/lodash": "4.14.123",
    "@types/react": "16.8.10",
    "@types/react-collapse": "4.0.2",
    "@types/react-dom": "16.8.3",
    "@types/storybook__addon-knobs": "4.0.4",
    "@types/storybook__react": "4.0.1",
    "@types/styled-components": "4.1.12",
    "@typescript-eslint/eslint-plugin": "1.5.0",
    "babel-eslint": "10.0.1",
    "babel-jest": "24.5.0",
    "babel-loader": "8.0.5",
    "babel-plugin-lodash": "3.3.4",
    "babel-plugin-styled-components": "1.10.0",
    "classnames": "2.2.6",
    "core-js": "3",
    "cross-env": "5.2.0",
    "css-loader": "2.1.1",
    "eslint": "5.16.0",
    "eslint-config-airbnb-typescript": "1.1.0",
    "eslint-config-prettier": "4.1.0",
    "eslint-loader": "2.1.2",
    "eslint-plugin-babel": "5.3.0",
    "eslint-plugin-import": "2.16.0",
    "eslint-plugin-jest": "22.4.1",
    "eslint-plugin-jsx-a11y": "6.2.1",
    "eslint-plugin-prettier": "3.0.1",
    "eslint-plugin-react": "7.12.4",
    "eslint-plugin-react-hooks": "1.6.0",
    "file-loader": "3.0.1",
    "fork-ts-checker-webpack-plugin": "1.0.1",
    "getstorybook": "1.7.0",
    "husky": "1.3.1",
    "identity-obj-proxy": "3.0.0",
    "jest": "24.5.0",
    "lint-staged": "8.1.5",
    "mini-css-extract-plugin": "0.5.0",
    "optimize-css-assets-webpack-plugin": "5.0.1",
    "postcss-color-function": "4.0.1",
    "postcss-cssnext": "3.1.0",
    "postcss-import": "12.0.1",
    "postcss-loader": "3.0.0",
    "postcss-nested": "4.1.2",
