{
  "name": "particular",
  "version": "0.1.0",
  "description": "An opinionated Particle Engine",
  "main": "./lib/index.js",
  "scripts": {
    "dev": "start-storybook -p 6006",
    "build": "npm run build-lib && npm run build-storybook",
    "build-storybook": "build-storybook -c .storybook -o ./docs",
    "build-lib": "webpack -p --config webpack.config.js --progress --colors",
    "build-lib-stats": "webpack -p --config webpack.config.js --profile --json > stats.json",
    "lint": "eslint **/*.js* && tslint src/**/*.ts* --project tsconfig.json",
    "test": "cross-env NODE_ENV=test karma start",
    "test:watch": "npm run test -- --singleRun=false",
    "storybook": "start-storybook -p 6006",
    "prettier:all": "prettier --write '**/*.*(js|jsx|ts|tsx|css|scss|scssm|json|md)'",
    "prepublish": "npm run build"
  },
  "author": "Niilo Säämänen <niilo@muffinssi.com>",
  "license": "MIT",
  "peerDependencies": {
    "classnames": "^2.2.0",
    "ramda": "^0.24.0",
    "react": "^16.1.1",
    "react-dom": "^16.1.1",
    "react-motion": "^0.5.0"
  },
  "devDependencies": {
    "@storybook/addon-actions": "3.4.1",
    "@storybook/addon-knobs": "3.4.1",
    "@storybook/react": "3.4.1",
    "@types/react": "16.3.10",
    "@types/react-dom": "16.0.5",
    "babel-cli": "6.26.0",
    "babel-core": "6.26.0",
    "babel-eslint": "8.2.3",
    "babel-loader": "7.1.4",
    "babel-plugin-lodash": "3.3.2",
    "babel-plugin-transform-class-properties": "6.24.1",
    "babel-plugin-transform-runtime": "6.23.0",
    "babel-preset-es2015": "6.24.1",
    "babel-preset-react": "6.24.1",
    "babel-preset-stage-0": "6.24.1",
    "babel-register": "6.26.0",
    "babel-runtime": "6.26.0",
    "chai": "4.1.2",
    "classnames": "2.2.5",
    "copy-webpack-plugin": "4.0.1",
    "cross-env": "5.1.3",
    "eslint": "4.14.0",
    "eslint-config-airbnb": "16.1.0",
    "eslint-config-prettier": "2.9.0",
    "eslint-loader": "2.0.0",
    "eslint-plugin-import": "2.11.0",
    "eslint-plugin-jsx-a11y": "6.0.3",
    "eslint-plugin-react": "7.7.0",
    "extract-text-webpack-plugin": "3.0.2",
    "file-loader": "1.1.11",
    "getstorybook": "1.7.0",
    "karma": "2.0.0",
    "karma-chai": "0.1.0",
    "karma-mocha": "1.3.0",
    "karma-mocha-reporter": "2.2.5",
    "karma-phantomjs-launcher": "1.0.4",
    "karma-sinon": "1.0.5",
    "karma-sinon-chai": "1.3.4",
    "karma-webpack": "3.0.0",
    "mocha": "5.1.0",
    "phantomjs-prebuilt": "2.1.16",
    "postcss-color-function": "4.0.1",
    "postcss-cssnext": "3.1.0",
    "postcss-import": "11.1.0",
    "postcss-loader": "2.1.3",
    "postcss-nested": "3.0.0",
    "postcss-units": "1.1.0",
    "prettier": "1.10.2",
    "ramda": "0.25.0",
    "react": "16.3.1",
    "react-display-name": "0.2.3",
    "react-dom": "16.3.1",
    "react-motion": "0.5.2",
    "react-redux": "5.0.7",
    "react-svg-loader": "2.1.0",
    "redux": "3.7.2",
    "sinon": "4.5.0",
    "sinon-chai": "3.0.0",
    "style-loader": "0.20.3",
    "ts-loader": "3.5.0",
    "tslint": "5.9.1",
    "tslint-config-prettier": "1.6.0",
    "tslint-loader": "3.6.0",
    "typescript": "2.8.1",
    "url-loader": "1.0.1",
    "webpack": "3.11.0",
    "webpack-dev-server": "2.11.2"
  },
  "dependencies": {
    "prop-types": "^15.6.0",
    "react-motion": "0.5.2",
    "react-portal": "~4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,scss,scssm,json,md}": [
      "prettier --write",
      "git add"
    ]
  }
}
